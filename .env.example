# ============================================================
# Root .env.example — copy to .env for docker-compose / local dev
# Per-app env files live at apps/api/.env and apps/web/.env.local
# ============================================================

# ----- API / Database -----
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cs_platform
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ----- Auth / JWT -----
JWT_ACCESS_SECRET=replace_me_with_32_byte_random_hex
JWT_REFRESH_SECRET=replace_me_with_32_byte_random_hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ----- Credential Encryption (AES-256-GCM) -----
# Generate with: openssl rand -base64 32
CREDS_ENCRYPTION_KEY=replace_with_32_byte_base64_key

# ----- Admin Bootstrap (used by `pnpm seed:admin`) -----
ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=ChangeMeNow!1234
ADMIN_FULL_NAME=Platform Admin

# ----- Cloudflare R2 (S3-compatible) -----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cs-platform-dev
R2_ENDPOINT=https://<accountId>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=

# ----- Email (Resend) -----
RESEND_API_KEY=
FROM_EMAIL=no-reply@example.com
CONTACT_INBOX_EMAIL=contact@example.com
MAIL_PROVIDER=console   # console | resend

# ----- Redis (Phase 2 / rate-limit store, optional in dev) -----
REDIS_URL=

# ----- Retention (days) -----
MOBILE_UPLOAD_RETENTION_DAYS=30
REPORT_RETENTION_DAYS=0           # 0 = indefinite
AUDIT_LOG_RETENTION_DAYS=365

# ----- PDF handling -----
# Server-side PDF encryption via qpdf (must be installed on API host)
PDF_SERVER_ENCRYPT=true
QPDF_BINARY=qpdf

# ----- Feature flags -----
FEATURES_AUTOSCAN=false

# ----- Web (Next.js) -----
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
