# ============================================================
# Web .env.example — copy to apps/web/.env.local for local dev
# ============================================================
#
# NEXT_PUBLIC_API_BASE_URL is the FULL API base, including the version
# prefix (`/api/v1`). The web client appends path-only routes to it
# (e.g. `${NEXT_PUBLIC_API_BASE_URL}/auth/login`).
#
# Production:
#   NEXT_PUBLIC_API_BASE_URL=https://api.secaudit.xyz/api/v1
#   NEXT_PUBLIC_APP_URL=https://secaudit.xyz
#
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
