# ============================================================
# API .env.example — copy to apps/api/.env for local dev
# ============================================================

NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
# Comma-separated list of allowed origins (preferred).
CORS_ORIGINS=http://localhost:3000
# Single-origin convenience var; appended to CORS_ORIGINS at runtime.
#
# Production (after 2026-05-09 subdomain move):
#   CORS_ORIGINS=https://app.secaudit.xyz,https://secaudit.xyz
#   (app subdomain = the SPA; apex = the marketing site contact form)
# In production set: CORS_ORIGIN=https://app.secaudit.xyz
CORS_ORIGIN=
# Cross-subdomain refresh-cookie domain (production only).
# Example: COOKIE_DOMAIN=.secaudit.xyz so the cookie set by api.secaudit.xyz
# is visible at app.secaudit.xyz (and the apex if ever needed).
# Leave empty for localhost dev.
COOKIE_DOMAIN=
# Force TLS to Postgres. Defaults: true in production, false elsewhere.
# Set to `true` for managed Postgres providers (Render, Supabase, RDS, ...).
DATABASE_SSL=

# ----- Database -----
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cs_platform

# ----- JWT (generate each with: openssl rand -hex 32) -----
JWT_ACCESS_SECRET=replace_me_access_32_byte_hex
JWT_REFRESH_SECRET=replace_me_refresh_32_byte_hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ----- Credential encryption (AES-256-GCM, 32 raw bytes base64) -----
CREDS_ENCRYPTION_KEY=replace_with_base64_of_32_random_bytes

# ----- Admin bootstrap (used by pnpm seed) -----
ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=ChangeMeNow!1234
ADMIN_FULL_NAME=Platform Admin

# ----- Cloudflare R2 -----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cs-platform-dev
R2_ENDPOINT=https://<accountId>.r2.cloudflarestorage.com

# ----- Email -----
MAIL_PROVIDER=console
RESEND_API_KEY=
FROM_EMAIL=no-reply@example.com
CONTACT_INBOX_EMAIL=contact@example.com
# Optional Resend-specific overrides. If unset, FROM_EMAIL and
# CONTACT_INBOX_EMAIL/ADMIN_EMAIL are used as fallbacks.
RESEND_FROM_EMAIL=
RESEND_ADMIN_EMAIL=

# ----- Redis / job queue -----
# When set AND `bullmq` + `ioredis` are installed, the JOB_QUEUE provider uses
# the Redis-backed BullMqJobQueue (active-scan jobs are dispatched to the
# isolated worker). When empty, a NoopJobQueue is used (jobs are logged, not
# dispatched). Install the deps with:
#   pnpm --filter @cs-platform/api add bullmq ioredis
REDIS_URL=

# ----- Retention -----
MOBILE_UPLOAD_RETENTION_DAYS=30
REPORT_RETENTION_DAYS=0
AUDIT_LOG_RETENTION_DAYS=365

# ----- PDF handling -----
PDF_SERVER_ENCRYPT=true
QPDF_BINARY=qpdf

# ----- Feature flags -----
FEATURES_AUTOSCAN=false

# When true, the auto-scan orchestrator runs Tier 2 scanners (nuclei + nikto)
# after Tier 1 succeeds. When false (default), Tier 2 is skipped entirely and
# the run is marked `complete` on Tier 1 success.
# Disabled by default: Tier 2 caused scans to hang on Render starter (512MB
# RAM, likely OOM during nuclei template load). Tier 1 (6 free, fast,
# non-blocking scanners) remains the production scan path. Re-enable once
# the orchestrator is hardened or the Render plan is upgraded.
AUTOSCAN_TIER_2_ENABLED=false

# When true, /auth/register sends a verification email and /auth/login
# rejects unverified accounts. When false (default), users are flagged
# emailVerified=true on creation, no verification email is sent, and
# login skips the verification gate. Flip to true once Resend is wired.
EMAIL_VERIFICATION_REQUIRED=false

# ============================================================
# Active / Deep Scan (paid, authorized, intrusive SkyNet scan)
# See ACTIVE_SCAN_DESIGN.md §7/§8. Requires REDIS_URL + the isolated worker
# stack (separate Render service). The backend is the control plane only.
# ============================================================

# Global kill-switch. When false (default), ALL new active-scan requests are
# rejected (existing jobs unaffected). Flip to true to enable the feature.
ACTIVE_SCAN_ENABLED=false

# Shared secret the isolated SkyNet worker presents in the `X-Worker-Secret`
# header on the internal results endpoints. Constant-time compared. Generate:
#   openssl rand -hex 32
# Leave empty to keep the internal worker endpoints fail-closed (reject all).
ACTIVE_SCAN_WORKER_SECRET=

# Secret used to sign the short-lived SSE stream tokens (EventSource can't send
# Authorization). If empty, falls back to JWT_ACCESS_SECRET. Generate:
#   openssl rand -hex 32
SCAN_STREAM_TOKEN_SECRET=
# Stream-token TTL in seconds (default 600 = 10 min).
SCAN_STREAM_TOKEN_TTL_SEC=600

# Days a verified target stays valid before re-verification is required.
ACTIVE_SCAN_VERIFY_TTL_DAYS=90

# Per-job wall-clock timeout (seconds) the worker honors (default 30 min).
ACTIVE_SCAN_JOB_TIMEOUT_SEC=1800

# Default scope handed to the worker (the saas profile also clamps these).
ACTIVE_SCAN_DEFAULT_MAX_HOSTS=4
ACTIVE_SCAN_DEFAULT_RATE=300
